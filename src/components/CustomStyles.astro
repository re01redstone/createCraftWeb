---
import '@fontsource-variable/inter';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap');

  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Orbitron', 'Inter Variable';

    --aw-color-primary: rgb(236 193 94);
    --aw-color-secondary: rgb(236 178 128);
    --aw-color-accent: rgb(20 184 166);

    --aw-color-text-heading: rgb(24 22 18);
    --aw-color-text-default: rgb(55 50 42);
    --aw-color-text-muted: rgb(100 92 80 / 80%);
    --aw-color-bg-page: rgb(235 245 255);

    --aw-color-bg-page-dark: rgb(5 4 3);

    ::selection {
      background-color: rgb(249 196 113 / 30%);
      color: rgb(24 22 18);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Orbitron', 'Inter Variable';

    --aw-color-primary: rgb(236 193 94);
    --aw-color-secondary: rgb(236 178 128);
    --aw-color-accent: rgb(20 184 166);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(10 8 36);

    ::selection {
      background-color: rgb(249 196 113 / 30%);
      color: snow;
    }
  }
</style>
