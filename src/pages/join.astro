---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';

import CreateCraft from '~/assets/images/CreateCraft.png';
const metadata = { title: '加入 CreateCraft' };
---

<Layout metadata={metadata}>

  <!-- Q群二维码 -->
  <Hero2
    actions={[
        {
        variant: 'primary',
        text: '配置教程',
        href: '/category/guide',
        icon: 'tabler:book',
        },
        {
        text: '查看公告',
        href: '/category/announcemnt',
        icon: 'tabler:speakerphone',
        },
    ]}
    image={{ src: CreateCraft, alt: 'CreateCraft QR code'}}
    title="加入CreateCraft"
    subtitle="QQ群号:597720420"
  >
  </Hero2>

</Layout>
