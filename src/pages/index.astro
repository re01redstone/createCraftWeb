---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import BlogHighlightedPosts from '~/components/widgets/BlogHighlightedPosts.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import indexHero from '~/assets/images/index-hero.png';


const metadata = {
  title: 'CreateCraft官方网站',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

<!-- Hero Widget -->
  <section class="relative h-[75vh] min-h-[500px] flex items-center justify-center text-center overflow-hidden">
    <!-- 背景图片 -->
    <img
      src={indexHero.src}
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-60"
    />
    <!-- 遮罩 -->
    <div class="absolute inset-0 bg-black/20"></div>
    <!-- 文字内容 -->
    <div class="relative z-10 px-6 max-w-4xl mx-auto">
      <p class="text-primary font-semibold uppercase tracking-[0.3em] text-sm mb-4 text-glow">
        Minecraft 生存服务器
      </p>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-4 tracking-tight animate-glow">
        CreateCraft
      </h1>
      <p class="text-xl text-gray-200 mb-8 font-light tracking-wide">
        机械动力/科技/探索/养老/魔法 Minecraft混合端服务器
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/category/guide"
          class="px-6 py-3 bg-primary/90 hover:bg-primary text-white font-semibold rounded-lg transition-all duration-300 shadow-lg shadow-primary/30 hover:shadow-primary/50 hover:scale-105 border border-primary/50">
          教程
        </a>
        <a href="/category/announcement"
          class="px-6 py-3 bg-[#c49a52] hover:bg-[#b5893b] text-white font-semibold rounded-lg transition-all duration-300 shadow-lg hover:scale-105 border border-[#daaf6b]">
          公告
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Announcement -->
  <BlogLatestPosts
    id="announcements"
    title="最新公告"
    information="服务器近期动态与更新通知"
    linkText="查看全部公告"
    linkUrl="/category/announcement"
    count={2}
    classes={{ container: 'game-panel rounded-xl' }}
  />


  <!-- View Archive -->
  <BlogHighlightedPosts
    id=""
    title="往期存档回顾"
    information="2024-至今, 我们共同的回忆"
    linkText="了解更多"
    linkUrl="/category/archive"
    postIds={[]}
    classes={{ container: 'game-panel rounded-xl' }}
  />

  <!-- this term intro -->
  <Features
  tagline="大开拓纪元落幕 · 末壤新生"
  title="CreateCraft2026"
  subtitle="养老/探险/空岛服 — 在浮空孤岛上重建文明"
  columns={3}
  items={[
    {
      title: '机械动力:航空学',
      description: '核心模组，航空学扩展让你在空岛间自由飞翔',
      icon: 'tabler:engine',
    },
    {
      title: '沉浸工程',
      description: '硬核重工业路线，发电厂与高压电网为孤岛供能',
      icon: 'tabler:bolt',
    },
    {
      title: '暮色森林',
      description: '穿越自然之门踏入第二大陆，资源富饶却危机四伏',
      icon: 'tabler:trees',
    },
    {
      title: '植物魔法',
      description: '用花朵与魔法搭建自然之门，跨越虚空裂痕',
      icon: 'tabler:flower',
    },
    {
      title: '养老生活',
      description: '森罗物语厨房酒馆、MCA村民、农夫乐事，悠闲度日',
      icon: 'tabler:home-heart',
    },
    {
      title: '阶段性解锁',
      description: '随进度逐步解锁新区域与科技，杜绝进度割裂，保持参与感',
      icon: 'tabler:lock-open',
    },
  ]}
  />

  <!--
  <Content
    tagline="下期预告"
    title=""
    subtitle="高版本原版生存建筑服务器"
    content="提供解谜等活动, 阶段性解锁下界/末地, 杜绝进度割裂"
    items={[
      { title: '版本', description: '26.x(待确定)', icon: 'tabler:cube' },
      { title: '开始时间', description: '2026年暑假', icon: 'tabler:calendar' },
      { title: 'Vulcan', description: '高版本将使用更加现代的渲染管线提升性能, 也意味着低配电脑也能开光影!', icon: 'tabler:package' },
    ]}
    callToAction={{ text: '查看开服公告', href: '/posts/season4-opening' }}
    image={{
      src: '/images/archives/s4-cover.jpg',
      alt: '第四期存档截图',
    }}
  />
  -->


  <!-- FAQs Widget ******************* -->

  <!-- Stats Widget ****************** -->


  <!-- CallToAction Widget *********** -->

  <CallToAction
      title="CreateCraft欢迎你的到来"
      subtitle="祝你在CreateCraft度过一段难忘的时光"
      classes={{ container: 'game-panel rounded-xl mt-8' }}
    actions={[
      {
        variant: 'primary',
        text: '加入Q群',
        href: '/join',
      },
    ]}
  >
  </CallToAction>
</Layout>
