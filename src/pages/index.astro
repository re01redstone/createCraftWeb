---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import heroBg from '~/assets/images/hero-bg.png';


const metadata = {
  title: 'AstroWind — Free template for creating websites with Astro + Tailwind CSS',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

<!-- Hero Widget -->
  <section class="relative h-[70vh] min-h-[400px] flex items-center justify-center text-center overflow-hidden">
    <!-- 背景图片 -->
    <img
      src={heroBg.src}
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
    />
    <!-- 遮罩，让文字更清晰 -->
    <div class="absolute inset-0 bg-black/50"></div>

    <!-- 文字内容 -->
    <div class="relative z-10 px-6 max-w-4xl mx-auto">
      <p class="text-blue-400 font-semibold uppercase tracking-widest text-sm mb-3">
        Minecraft 生存服务器
      </p>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-4">
        CreateCraft官方网站
      </h1>
      <p class="text-xl text-gray-200 mb-8">
      机械动力/通用机械/原版 Minecraft服务器
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/category/guide"
          class="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white font-semibold rounded-lg transition-colors">
          教程
        </a>
        <a href="/category/announcement"
          class="px-6 py-3 bg-white/20 hover:bg-white/30 text-white font-semibold rounded-lg backdrop-blur-sm transition-colors border border-white/30">
          公告
        </a>
      </div>
    </div>
  </section>

  <!-- Latest Announcement -->
  <BlogLatestPosts
    id="announcements"
    title="最新公告"
    information="服务器近期动态与更新通知"
    linkText="查看全部公告"
    linkUrl="/category/announcement"
    count={2}
  />


  <!-- View Archive -->
  <BlogLatestPosts
    id="archive"
    title="往期存档回顾"
    information="2024-至今, 我们共同的回忆"
    linkText="了解更多"
    linkUrl="/category/archive"
    count={2}
  />

  <!-- this term intro -->
  <Features
  tagline="即将开启"
  title="CreateCraft2026"
  subtitle="高版本原版生存建筑服务器"
  columns={3}
  items={[
    {
      title: '游戏版本',
      description: '26.1+ spigot',
      icon: 'tabler:cube',
    },
    {
      title: '预计开服',
      description: '2026暑假',
      icon: 'tabler:calendar',
    },
    {
      title: '插件',
      description: 'SimpleTpa,MultiLogin,Dynmap,AllMusic等',
      icon: 'tabler:package',
    },
    {
      title: '活动',
      description: '周期性解谜, 建筑大赛等',
      icon: 'tabler:activity',
    },
    {
      title: '进度管理',
      description: '阶段性解锁下界/末地, 保证参与感',
      icon: 'tabler:lock',
    },
    {
      title: '优秀管理',
      description: 'nb的腐竹保证服务器安全稳定运行',
      icon: 'tabler:shield-half',
    },
  ]}
  />

  <!--
  <Content
    tagline="下期预告"
    title=""
    subtitle="高版本原版生存建筑服务器"
    content="提供解谜等活动, 阶段性解锁下界/末地, 杜绝进度割裂"
    items={[
      { title: '版本', description: '26.x(待确定)', icon: 'tabler:cube' },
      { title: '开始时间', description: '2026年暑假', icon: 'tabler:calendar' },
      { title: 'Vulcan', description: '高版本将使用更加现代的渲染管线提升性能, 也意味着低配电脑也能开光影!', icon: 'tabler:package' },
    ]}
    callToAction={{ text: '查看开服公告', href: '/posts/season4-opening' }}
    image={{
      src: '/images/archives/s4-cover.jpg',
      alt: '第四期存档截图',
    }}
  />
  -->


  <!-- FAQs Widget ******************* -->

  <!-- Stats Widget ****************** -->


  <!-- CallToAction Widget *********** -->

  <CallToAction
      title="CreateCraft欢迎你的到来"
      subtitle="祝你在CreateCraft度过一段难忘的时光"
    actions={[
      {
        variant: 'primary',
        text: '加入我们',
        href: '/join',
      },
    ]}
  >
  </CallToAction>
</Layout>
